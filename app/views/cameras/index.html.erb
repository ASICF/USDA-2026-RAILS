
<div class="ui breadcrumb">
    <div class="section">Manage</div>
    <span class="divider">/</span>
    <div class="section">Cameras</div>
    <span class="divider">/</span>
    <div class="active section">All</div>
</div>

<%= link_to new_camera_path, class: "ui right floated labeled icon tiny primary button" do %>
    <i class="plus icon"></i>
    New camera
<% end %>

<div class="clear"></div>
<div class="ui divider"></div>

<table class="ui sortable center aligned celled padded table" style="margin-bottom: 2em;">
    <thead>
        <tr>
            <th>Name</th>
            <th>Company</th>
            <th>Manufacturer</th>
            <th>Model</th>
            <th>Serial Number</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
<% @cameras.each do |camera| %>
    <tr>
        <td><%= camera.name %></td>
        <td><%= camera.company.name %></td>
        <td><%= camera.manufacturer %></td>
        <td><%= camera.model %></td>
        <td><%= camera.serial_number %></td>
        <td class="collapsing">
            <%= link_to edit_camera_path(camera), class: "ui tiny icon secondary button" do %>
                <i class="setting icon"></i>
            <% end %>
        </td>
    </tr>
<% end %>
    </tbody>
    <% if @cameras.total_pages > 1 %>
        <tfoot>
            <tr>
                <th colspan="3" style="text-align: center;">
                    <%= paginate(@cameras, window: 1, outer_window: 1) %>
                </th>
            </tr>
        </tfoot>
    <% end %>
</table>
