

<div class="ui breadcrumb">
  <div class="section">Manage</div>
  <span class="divider">/</span>
  <div class="section">Companies</div>
  <span class="divider">/</span>
  <div class="active section">All</div>
</div>

<%= link_to new_company_path, class: "ui right floated primary right labeled icon small button" do %>
  <i class="plus icon"></i>
  New Company
<% end %>

<div class="ui divider"></div>
<div class="clear"></div>

<table class="ui sortable celled striped table" style="margin-bottom: 2em;">
  <thead>
      <tr>
          <th>Name</th>
          <th>Alias</th>
          <th>Planes</th>
          <th>Cameras</th>
          <th></th>
      </tr>
  </thead>
  <tbody>

  <% @companies.each do |company| %>

    <tr>
      <td><%= company.name %></td>
      <td><%= company.alias %></td>
      <td><%= company.planes.count %></td>
      <td><%= company.cameras.count %></td>
      <td class="collapsing">
          <%= link_to edit_company_path(company), class: "ui tiny icon secondary button" do %>
            <i class="setting icon"></i>
          <% end %>
      </td>
    </tr>

  <% end %>

  </tbody>
  <% if @companies.total_pages > 1 %>
      <tfoot>
          <tr>
              <th colspan="4" style="text-align: center;">
                  <%= paginate(@companies, window: 1, outer_window: 1) %>
              </th>
          </tr>
      </tfoot>
  <% end %>
</table>