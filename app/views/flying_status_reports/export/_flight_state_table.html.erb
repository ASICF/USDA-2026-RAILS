<table>
    <thead>
        <tr>
            <th>Report</th>
            <th>Scope</th>
            <th>Date Flown From</th>
            <th>Date Flown To</th>
            <th>Date Created</th>
            <th>Report URL</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>Flying Status Report</td>
            <td>All Sites by State</td>
            <td><%= @date_flown_from.strftime("%m/%d/%Y") %></td>
            <td><%= @date_flown_end.strftime("%m/%d/%Y") %></td>
            <td><%= Time.now.strftime("%m/%d/%Y") %></td>
            <td><%= flying_scanning_reports_url %></td>
        </tr>
    </tbody>
</table>

<br/>
<br/>

<table>
    <thead>
        <tr>
            <th colspan="9">Flight Summary</th>
        </tr>
        <tr>
            <th>Project ID</th>
            <th>State</th>
            <th>Total Sites</th>
            <th>Total Flown</th>
            <th>Accepted</th>
            <th>Rejected</th>
            <th>% Accepted</th>
            <th>% Rejected</th>
            <th>% Total Completed</th>
        </tr>
    </thead>
    <tbody>

    <% 
        total_sites = total_flown = total_accepted = total_rejected = 0
        grand_total_sites = grand_total_flown = grand_total_accepted = grand_total_rejected = 0
    %>

    <% @configs.sort_by {|c| c.state.name}.each_with_index do |config, index| %>

        <% 
            scoped_post_flight_records = config.post_flight_records.where(flight_date: @date_flown_from..@date_flown_end)
        %>

        <tr>
            <td><%= config.project_no %></td>
            <td><%= config.state.name %></td>
            <td><%= config.pre_flight_records.count %></td>
            <td><%= scoped_post_flight_records.count %></td>
            <td><%= scoped_post_flight_records.flown.count %></td>
            <td><%= scoped_post_flight_records.not_flown.count %></td>
            <td><%= (scoped_post_flight_records.flown.count.to_f / scoped_post_flight_records.count * 100).round(2) %></td>
            <td><%= (scoped_post_flight_records.not_flown.count.to_f / scoped_post_flight_records.count * 100).round(2) %></td>
            <td><%= (scoped_post_flight_records.flown.count.to_f / config.pre_flight_records.count * 100).round(2) %></td>
        </tr>

        <%

            total_sites += config.pre_flight_records.count
            total_flown += scoped_post_flight_records.count
            total_accepted += scoped_post_flight_records.flown.count
            total_rejected += scoped_post_flight_records.not_flown.count

            next_config = @configs[index + 1]
            build_total = false
            build_grand_total = false

            if next_config.nil?
                build_total = build_grand_total = true

                grand_total_sites += total_sites
                grand_total_flown += total_flown
                grand_total_accepted += total_accepted
                grand_total_rejected += total_rejected
            end

        %>

    <% end %>
    </tbody>
</table>