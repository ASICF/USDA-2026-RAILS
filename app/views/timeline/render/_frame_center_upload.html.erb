<% content_for :template, "large-screen" %>
<% @upload = @history.uploads.first %>

<div class="ui segment">
    <table class="ui center aligned fluid very basic table">
        <thead>
            <tr>
                <th class="ten wide">Message</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td class="collapsing"><%= @history.message %></td>
            </tr>
        </tbody>
    </table>

    <table class="ui three column fluid very basic table">
        <thead>
            <tr class="center aligned">
                <th>Created</th>
                <th>Submitted By</th>
                <th>Download</th>
            </tr>
        </thead>
        <tbody>
            <tr class="center aligned">
                <td><%= @upload.created_at.localtime.strftime("%m/%d/%Y %I:%M %p") %></td>
                <td>
                    <div class="ui label">
                        <i class="user icon"></i> <%= @upload.uploader.full_name %>
                    </div>
                </td>
                <td>
                    <%= link_to download_upload_original_path(@upload), target: "_blank", class: "ui tiny icon secondary button" do %>
                        <i class="download icon"></i>
                        Download
                    <% end %>
                </td>
            </tr>
        </tbody>
    </table>
</div>

<div class="ui divider"></div>

<table class="ui sortable center aligned celled striped table" style="margin-bottom: 2em;">
    <thead>
        <tr>
            <th>Strip Frame</th>
            <th>Flight Date</th>
            <th>GPS Time</th>
            <th>X</th>
            <th>Y</th>
            <th>Z</th>
            <th>Omega</th>
            <th>Phi</th>
            <th>Kappa</th>
            <th>Latitude</th>
            <th>Longitude</th>
            <th>Created At</th>
        </tr>
    </thead>
    <tbody>
        <% @upload.frame_centers.each do |log| %>
            <tr>
                <td><%= log.strip_frame %></td>
                <td><%= log.flight_date.strftime("%m/%d/%Y %I:%M %p") %></td>
                <td><%= log.gpstime %></td>
                <td><%= log.x %></td>
                <td><%= log.y %></td>
                <td><%= log.z %></td>
                <td><%= log.omega %></td>
                <td><%= log.phi %></td>
                <td><%= log.kappa %></td>
                <td><%= log.latitude %></td>
                <td><%= log.longitude %></td>
                <td><%= log.created_at.localtime.strftime("%m/%d/%Y %I:%M %p") %></td>
            </tr>
        <% end %>
    </tbody>
</table>
