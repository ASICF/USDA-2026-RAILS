<% content_for :template, "large-screen" %>
<% @upload = @history.uploads.first %>

<div class="ui segment">
    <table class="ui center aligned fluid very basic table">
        <thead>
            <tr class="center aligned">
                <th>Message</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td class="collapsing"><%= @history.message %></td>
            </tr>
        </tbody>
    </table>

    <table class="ui three column fluid very basic table">
        <thead>
            <tr class="center aligned">
                <th>Created</th>
                <th>Submitted By</th>
                <th>Download</th>
            </tr>
        </thead>
        <tbody>
            <tr class="center aligned">
                <td><%= @upload.created_at.localtime.strftime("%m/%d/%Y %I:%M %p") %></td>
                <td>
                    <div class="ui label">
                        <i class="user icon"></i> <%= @upload.uploader.full_name %>
                    </div>
                </td>
                <td>
                    <%= link_to download_upload_original_path(@upload), target: "_blank", class: "ui tiny icon secondary button" do %>
                        <i class="download icon"></i>
                        Download
                    <% end %>
                </td>
            </tr>
        </tbody>
    </table>
</div>

<div class="ui divider"></div>

<table class="ui sortable center aligned celled striped table" style="margin-bottom: 2em;">
    <thead>
        <tr>
            <th>AT Start</th>
            <th>AT Done</th>
            <th>AT Start Date</th>
            <th>AT Done Date</th>
            <th>Created At</th>
        </tr>
    </thead>
    <tbody>

        <% 
            records = @upload.airborne_digital_sensors.count > 0 ? @upload.airborne_digital_sensors : @history.airborne_digital_sensors
        %>

        <% records.each do |record| %>
            <tr>
                <td><%= record.at_start_date ? "Yes" : "No" %></td>
                <td><%= record.at_done_date ? "Yes" : "No" %></td>
                <td><%= record.at_start_date.present? ? record.at_start_date.strftime("%m/%d/%Y %I:%M %p") : "NA" %></td>
                <td><%= record.at_done_date.present? ? record.at_done_date.strftime("%m/%d/%Y %I:%M %p") : "NA" %></td>
                <td><%= record.created_at.localtime.strftime("%m/%d/%Y %I:%M %p") %></td>
            </tr>
        <% end %>
    </tbody>
</table>
